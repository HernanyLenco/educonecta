// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum acesso{
ALUNO
PROFESSOR
ENCARREGADO
ADMIN
}

model user{
id String @id @unique
email String @unique
senha String
nivel acesso @default(ALUNO)

areaAdministrativas areaAdministrativa[]

professors professor[]

encarregados encarregado[]

alunos aluno[]
}

model aluno {
  id String   @id @unique
  nome String
  email String @unique
  numeroDeEstudante Int @unique @default(autoincrement())
  idade Int
  genero String
  createdAt DateTime @default(now())

  userId String @unique //chave estrangeira para a tabela de alunos

  perfilDeLogin user @relation(fields: [userId], references: [id], onDelete: Cascade) // relacao entre aluno e o enum user.
}

model encarregado {
  id String   @id @unique
  nome String
  profissao String
  email String   @unique
  numeroDeTelefone Int @unique
  createdAt DateTime @default(now())

  userId String @unique //chave estrangeira para a tabela de encarregados

  perfilDeLogin user @relation(fields: [userId], references: [id], onDelete: Cascade) // relacao entre encarregado e o enum user.
}

model faculdade {
  id   String @id @unique
  nome String
}

model cadeiras {
  id Int @unique @default(autoincrement())
  nome String
}

model professor {
  id  String @id @unique
  nome String
  email String @unique
  numeroDeTelefone Int @unique

  userId String @unique //chave estrangeira para a tabela de professores
  perfilDeLogin user @relation(fields: [userId], references: [id], onDelete: Cascade) // relacao entre professor e o enum user.
}

model areaAdministrativa {
  id   String @id @unique
  nome String
  email String @unique

  userId String @unique //chave estrangeira para a tabela de areaAdministrativa
  perfilDeLogin user @relation(fields: [userId], references: [id], onDelete: Cascade) // relacao entre areaAdministrativa e o enum user.
} 
